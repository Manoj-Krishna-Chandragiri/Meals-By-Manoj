# ============================================================
# Dependencies — never commit node_modules
# ============================================================
node_modules/
**/node_modules/

# ============================================================
# Environment files — NEVER commit secrets
# ============================================================
.env
.env.local
.env.production
.env.staging
backend/.env
frontend/.env
admin/.env
**/.env

# ============================================================
# Build outputs
# ============================================================
dist/
**/dist/
dist-ssr/

# ============================================================
# Uploaded user files (backend)
# ============================================================
backend/uploads/*
!backend/uploads/.gitkeep

# ============================================================
# Logs
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================
# Editor / OS artifacts
# ============================================================
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================================
# Package manager cache
# ============================================================
.npm
.yarn/cache
.pnp.*
