# ── Server ────────────────────────────────────────────────
PORT=4000

# ── MongoDB ───────────────────────────────────────────────
# Replace with your Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/food-delivery

# ── JWT ───────────────────────────────────────────────────
# Use a long random string (e.g. openssl rand -base64 48)
JWT_SECRET=replace_with_a_strong_random_secret

# ── Stripe ────────────────────────────────────────────────
# IMPORTANT: rotate your Stripe key at https://dashboard.stripe.com/apikeys
# Use a TEST key (sk_test_...) for development
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_key

# ── Frontend URL (for Stripe redirect) ───────────────────
FRONTEND_URL=http://localhost:5173
