# ── Server ────────────────────────────────────────────────
PORT=4000

# ── MongoDB ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/food-delivery

# ── JWT ────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_random_secret

# ── Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_key

# ── CORS allowed origins ─────────────────────────────
# Your frontend domain (used for Stripe redirect + CORS)
FRONTEND_URL=https://meals-by-manoj.manojkrishna.tech
# Your admin panel domain
ADMIN_URL=https://meals-by-manoj-admin.onrender.com
